# Copy this file to .env.local (gitignored) for local development against
# the Firestore emulator. `demo-`-prefixed project ids are Firebase's
# convention for emulator-only projects - no real Firebase project needed
# to develop locally.
VITE_USE_EMULATOR=true
VITE_FIREBASE_PROJECT_ID=demo-village-map
VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-village-map.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=demo-village-map.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=demo-app-id
