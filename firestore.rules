rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /maps/{mapId} {
      allow read, write: if true; // TODO: tighten to `if request.auth != null` once auth is added

      match /plots/{plotId} {
        allow read, write: if true; // TODO: tighten to `if request.auth != null` once auth is added
      }
    }
  }
}
